# Copy to .env on the host and customize.

# Pin the cloudflared image. Tags: https://hub.docker.com/r/cloudflare/cloudflared/tags
# Exception to the repo-wide "never :latest" rule: this example tracks
# the floating tag so the file doesn't rot every release. Override with
# a specific version in your host-local .env when you want reproducibility.
CLOUDFLARED_TAG=latest

# Connector token from the Cloudflare dashboard:
#   Zero Trust → Networks → Tunnels → <tunnel> → Install connector → Docker
# It's a long base64-encoded string. Treat as a secret; .env is gitignored.
CLOUDFLARE_TUNNEL_TOKEN=
