# openai/gpt-oss-120b · already in /opt/hf/.cache on this host.
# Self-contained — `make up VARIANT=gpt-oss-120b` copies this to .env.

VLLM_TAG=v0.20.2
HF_CACHE_HOST=/opt/hf/.cache/huggingface
HF_TOKEN=

VLLM_MODEL=openai/gpt-oss-120b
VLLM_SERVED_NAME=gpt-oss-120b
VLLM_GPU_MEM=0.9
VLLM_MAX_LEN=8192
