# vLLM image. Multi-arch (amd64 + arm64). Compute capability 12.1 (GB10)
# is not on vLLM's published support matrix — this stack is scaffolded but
# not yet smoke-tested on the host. Bring up at your own risk; first run
# may fail if sm_120 kernels aren't compiled into the image.
VLLM_TAG=v0.20.2

# HuggingFace model ID (repo). vLLM loads safetensors directly; not GGUF.
# Pick a model that fits your VRAM budget. Examples:
#   Qwen/Qwen2.5-7B-Instruct
#   meta-llama/Llama-3.1-8B-Instruct          (gated — needs HF_TOKEN)
#   microsoft/Phi-3.5-mini-instruct
#   mistralai/Mistral-7B-Instruct-v0.3        (gated)
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# Name surfaced via the OpenAI-compatible API. Defaults to VLLM_MODEL.
#VLLM_SERVED_NAME=qwen2.5-7b

# Fraction of GPU memory vLLM may use (0.0–1.0).
VLLM_GPU_MEM=0.9

# Maximum context length. Larger values need more KV-cache memory.
VLLM_MAX_LEN=8192

# Path on the host that holds the HuggingFace CLI cache. Mounted read-write
# so vLLM and `hf` CLI share the same downloads.
HF_CACHE_HOST=/opt/hf/.cache/huggingface

# Optional HuggingFace access token (gated/private models).
HF_TOKEN=
