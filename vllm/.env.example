# Copy this to .env once on the host (`cp .env.example .env`) — `make up`
# does this automatically on first invocation. The values here are
# placeholders that satisfy the compose file's required-var checks so
# raw `docker compose ps / logs / down` work without --env-file.
#
# `make up ENV=<name>` overrides everything with the chosen variant in
# envs/<name>.env at start time, so these placeholder values are only
# what compose sees when reading .env on its own.

# vLLM image. Multi-arch (amd64 + arm64).
VLLM_TAG=v0.20.2

# Host path holding the HuggingFace CLI cache. Mounted read-write so vLLM
# and `hf` CLI share downloads.
HF_CACHE_HOST=/opt/hf/.cache/huggingface

# Optional HuggingFace token (gated/private models — meta-llama/*, etc.)
HF_TOKEN=

# Placeholders — required by the compose file's ${VAR:?...} checks. The
# real values come from envs/<name>.env via `make up ENV=<name>`.
VLLM_MODEL=placeholder
VLLM_SERVED_NAME=placeholder
VLLM_GPU_MEM=0.9
VLLM_MAX_LEN=8192
