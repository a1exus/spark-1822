# `make up VARIANT=<name>` copies envs/<name>.env over this .env, so this
# file is just a reference template showing every variable a variant sets.
# You shouldn't need to edit this directly.

# vLLM image. Multi-arch (amd64 + arm64).
VLLM_TAG=v0.20.2

# Host path holding the HuggingFace CLI cache. Mounted read-write so vLLM
# and `hf` CLI share downloads.
HF_CACHE_HOST=/opt/hf/.cache/huggingface

# Optional HuggingFace token (gated/private models — meta-llama/*, etc.)
HF_TOKEN=

# Required model selection.
VLLM_MODEL=
VLLM_SERVED_NAME=
VLLM_GPU_MEM=0.9
VLLM_MAX_LEN=8192
