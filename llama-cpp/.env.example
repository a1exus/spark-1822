# Copy this to .env once on the host (`cp .env.example .env`) — `make up`
# does this automatically on first invocation. Required by the compose
# file's ${VAR:?...} checks so raw `docker compose ps / logs / down` work
# without --env-file.
#
# `make up ENV=<name>` overrides everything with the chosen variant in
# envs/<name>.env at start time, so the placeholder MODEL_* values below
# are only what compose sees when reading .env on its own.

# llama.cpp image — pin by digest of the multi-arch manifest list so Docker
# picks the correct arch (arm64 on this host) deterministically.
LLAMACPP_TAG=server-cuda@sha256:a04923d31b4ca0d95bd772a4b80c9112f29121014df64d3d80a16a136ca19672

# Host path holding the HuggingFace CLI cache. Mounted read-only.
HF_CACHE_HOST=/opt/hf/.cache/huggingface

# Optional HuggingFace token (gated/private models only). Public models
# need nothing.
HF_TOKEN=

# Placeholders for the model-source vars. Each variant in envs/ sets one
# of MODEL_PATH / MODEL_OLLAMA / MODEL_URL. The compose file uses
# ${VAR:-} defaults for these (no :? strict-required check), so leaving
# them empty is fine for raw `docker compose` commands.
MODEL_PATH=
MODEL_OLLAMA=
MODEL_URL=

# Surfaced via the OpenAI-compatible API.
MODEL_ALIAS=llama-cpp

# Context window and GPU offload.
CTX_SIZE=8192
N_GPU_LAYERS=999
