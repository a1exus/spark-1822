# `make up VARIANT=<name>` copies envs/<name>.env over this .env, so this
# file is just a reference template showing every variable a variant sets.
# You shouldn't need to edit this directly.

# llama.cpp image — pin by digest of the multi-arch manifest list so Docker
# picks the correct arch (arm64 on this host) deterministically.
LLAMACPP_TAG=server-cuda@sha256:a04923d31b4ca0d95bd772a4b80c9112f29121014df64d3d80a16a136ca19672

# Host path holding the HuggingFace CLI cache. Mounted read-only.
HF_CACHE_HOST=/opt/hf/.cache/huggingface

# Optional HuggingFace token (gated/private models only). Public models
# need nothing.
HF_TOKEN=

# Choose ONE of these to point at the model:
#   MODEL_PATH   — file inside the container (Ollama blob / HF snapshot / cache)
#   MODEL_OLLAMA — Ollama model:tag, resolved at start via /ollama manifest store
#   MODEL_URL    — remote URL, cached in the llama-cpp-cache volume
MODEL_PATH=
MODEL_OLLAMA=
MODEL_URL=

# Surfaced via the OpenAI-compatible API.
MODEL_ALIAS=llama-cpp

# Context window and GPU offload.
CTX_SIZE=8192
N_GPU_LAYERS=999
